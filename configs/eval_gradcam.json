{
  "paths": {
    "image_dir": "data/images",
    "mask_dir": "data/masks",
    "output_dir": "results/gradcam"
  },
  "checkpoints": {
    "CNN": "results/cnn/best_model/best_cnn.pth",
    "ResNet-50": "results/resnet50/best_model/best_resnet50.pth",
    "Swin-T": "results/swin_t/best_model/best_swin_t.pth"
  },
  "model_files": {
    "CNN": "src/cnn/custom_cnn.py",
    "ResNet-50": "src/resnet50/resnet50.py",
    "Swin-T": "src/swin_t/swin_t.py"
  },
  "vlm_summaries": {
    "CLIP": "results/vlm/clip/summary.json",
    "DermLIP": "results/vlm/dermlip/summary.json"
  },
  "vlm_models": {
    "CLIP": {
      "model_id": "ViT-B-16",
      "pretrained": "openai"
    },
    "DermLIP": {
      "model_id": "hf-hub:redlessone/DermLIP_ViT-B-16",
      "pretrained": null
    }
  },
  "target_layers": {
    "CNN": "block4.0",
    "ResNet-50": "layer4[-1]",
    "Swin-T": "layers[-1].blocks[-1].attn"
  },
  "eval": {
    "image_size": 224,
    "threshold": 0.5,
    "minority_classes": ["DF", "VASC"],
    "samples_per_figure": 2
  },
  "class_names": [
    "melanoma",
    "melanocytic nevi",
    "basal cell carcinoma",
    "actinic keratosis",
    "benign keratosis",
    "dermatofibroma",
    "vascular lesions"
  ]
}
